### https://raw.github.com/github/gitignore/master/Rust.gitignore

# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Vagrant / kernel matrix (built on host, not committed)
scripts/vm/artifacts/
scripts/vm/matrix-results/

# These are backup files generated by rustfmt
**/*.rs.bk
src/proto/aegis.rs
# Track generated C header
!include/aegis.h
